# OpenAI API Configuration
# 若不配置，将自动使用 mock 模式运行（不调用真实 API）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# 字段映射配置（可选，默认为内置映射）
# CUSTOM_FIELD_MAPPING_PATH=./config/field-mapping.json

# LLM 调用配置
# 最大并发数（默认 5）
# MAX_CONCURRENT_REQUESTS=5

# 输出配置
# 默认输出目录
# OUTPUT_DIR=./output
